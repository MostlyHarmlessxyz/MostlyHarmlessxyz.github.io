---
import PostCard from "../components/PostCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getAllPosts } from "../utils/posts";

const posts = await getAllPosts();
const recentPosts = posts.slice(0, 3);
---

<BaseLayout title="Mostly Harmless" description="Mostly_Harmless 的碎碎念">
  <section class="intro-section">
    <p class="eyebrow">碎碎念</p>
    <h1>写给未来自己的呓语。</h1>
    <p class="intro-copy">
      Powered by xyz.
    </p>
    <div class="intro-actions">
      <a class="button" href="/blog/">阅读文章</a>
      <a class="button secondary" href="/about/">关于我</a>
    </div>
  </section>

  <section class="section-block" aria-labelledby="recent-posts">
    <div class="section-heading">
      <h2 id="recent-posts">最新文章</h2>
      <a href="/blog/">全部文章</a>
    </div>
    <div class="post-grid">
      {recentPosts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>
